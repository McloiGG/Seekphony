# Seekphony Compose configuration.
# Copy to root .env only for local Docker Compose runs.
# Do not commit root .env or real secrets.

SEEKPHONY_APP_NAME=Seekphony Backend
SEEKPHONY_API_PREFIX=/api/v1
SEEKPHONY_DATA_DIR=/app/var
SEEKPHONY_DATABASE_PATH=/app/var/seekphony.sqlite3
SEEKPHONY_SEED_PATH=/app/data/seeds/songs.json
SEEKPHONY_UPLOAD_DIR=/app/var/uploads
SEEKPHONY_MAX_UPLOAD_BYTES=15728640
SEEKPHONY_PROVIDER_TIMEOUT_SECONDS=8
SEEKPHONY_PROVIDER_RETRY_COUNT=2
SEEKPHONY_PROVIDER_RETRY_DELAY_SECONDS=0.5
SEEKPHONY_ENABLE_SHAZAMIO=false
SEEKPHONY_CORS_ORIGINS=*

# Optional free-tier/model providers. Backend boots without these.
GEMINI_API_KEY=
GOOGLE_API_KEY=
SEEKPHONY_GEMINI_MODEL=gemini-2.5-flash
