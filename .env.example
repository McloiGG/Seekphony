# Seekphony Compose configuration.
# Copy to root .env only for local Docker Compose runs.
# Do not commit root .env or real secrets.

SEEKPHONY_APP_NAME=Seekphony Backend
SEEKPHONY_API_PREFIX=/api/v1
SEEKPHONY_DATA_DIR=/app/var
SEEKPHONY_DATABASE_PATH=/app/var/seekphony.sqlite3
SEEKPHONY_MAX_UPLOAD_BYTES=31457280
SEEKPHONY_MIN_CLIP_SECONDS=5
SEEKPHONY_MAX_CLIP_SECONDS=60
SEEKPHONY_DECODE_TIMEOUT_SECONDS=15
SEEKPHONY_PROVIDER_TIMEOUT_SECONDS=8
SEEKPHONY_CORS_ORIGINS=*

# Optional deployment database. Leave empty for local SQLite.
DATABASE_URL=

# Optional Gemini explanation provider. Backend returns metrics without this.
GEMINI_API_KEY=
GOOGLE_API_KEY=
SEEKPHONY_GEMINI_MODEL=gemini-3.1-flash-lite

# Public browser configuration. This is not a secret.
SEEKPHONY_PUBLIC_API_BASE_URL=http://localhost:8000
SEEKPHONY_FRONTEND_PORT=5173
