#!/usr/bin/env sh
set -eu

hook_dir=$(case "$0" in */*) printf "%s\n" "${0%/*}" ;; *) printf ".\n" ;; esac)
. "${hook_dir}/_common.sh"

zero_sha="0000000000000000000000000000000000000000"
ranges=""

while read -r local_ref local_oid remote_ref remote_oid; do
    if [ "${local_oid}" = "${zero_sha}" ]; then
        continue
    fi

    if [ "${remote_oid}" = "${zero_sha}" ]; then
        ranges="${ranges}
${local_oid}"
    else
        ranges="${ranges}
${remote_oid}..${local_oid}"
    fi
done

cd "$(repo_root)"
run_python_checks_if_possible
run_ruff_if_possible

for revision_range in ${ranges}; do
    run_git log --format=%s "${revision_range}" | while IFS= read -r subject; do
        if ! validate_conventional_subject "${subject}"; then
            echo "Commit message must follow Conventional Commits v1.0.0." >&2
            echo "Range: ${revision_range}" >&2
            echo "Actual: ${subject}" >&2
            exit 1
        fi
    done
done
